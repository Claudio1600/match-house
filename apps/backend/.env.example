# Database — Supabase (connection pooler per app, direct per migrazioni)
DATABASE_URL="postgresql://postgres.uvfpwsydthwinihanxhg:[YOUR-PASSWORD]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.uvfpwsydthwinihanxhg:[YOUR-PASSWORD]@aws-0-eu-north-1.pooler.supabase.com:5432/postgres"

# Redis — Upstash (redis://default:[PASSWORD]@xxxx.upstash.io:6379)
REDIS_URL=redis://localhost:6379

# JWT — genera stringhe random di almeno 32 caratteri
JWT_SECRET=your-super-secret-key-min-32-chars-here!!
JWT_REFRESH_SECRET=another-secret-for-refresh-tokens-32chars

# Cloudinary — https://cloudinary.com (opzionale per il dev locale)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email — SendGrid o altro SMTP (opzionale per il dev locale)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@matchhouse.app

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8081
